rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper: check if the caller is an admin ---
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/config/admin)
        && request.auth.token.email in get(/databases/$(database)/documents/config/admin).data.admin_emails;
    }

    // --- Users ---
    // Users can read/write their own document. Admins can read/update any user.
    // Users cannot change their own plan fields — only admins can.
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan', 'plan_started_at', 'plan_expires_at']);
      // TEMPORARY: allow users to self-switch plans during testing.
      // TODO: Remove this rule before production — plan changes should only
      // come from the server after Stripe payment confirmation.
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['plan']);
      allow update: if isAdmin();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Saved scans subcollection — owner only
      match /saved_scans/{scanId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Garage subcollection — owner only
      match /garage/{vehicleId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Purchases subcollection — owner can read, server creates via REST API
      match /purchases/{purchaseId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Only written by Cloud Run webhook
      }

      // Usage tracking subcollection — owner can read/write, admins can read
      match /usage/{monthId} {
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow create, update: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- Plan configuration ---
    // Any authenticated user can read plan details. Only admins can modify.
    match /config/plans {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // --- Admin config ---
    // Only admins can read. Only admins can write (except first-time bootstrap).
    match /config/admin {
      // Allow read for any authenticated user (needed to check if they are admin).
      // The admin check itself is done client-side; the sensitive data is just an email list.
      allow read: if request.auth != null;

      // Allow create if no admin doc exists yet (bootstrap by first user)
      allow create: if request.auth != null;

      // Only existing admins can update the admin list
      allow update: if isAdmin();
      allow delete: if false;
    }

    // --- Shared Vehicle Reports ---
    // Anyone can read (public links). Only authenticated owner can create/update/delete.
    match /shared_reports/{reportId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.owner_uid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.owner_uid == request.auth.uid;
    }

    // --- AI Reports ---
    // Authenticated users can create reports. Only admins can read/update/delete.
    match /ai_reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // --- Lockout Events ---
    // Authenticated users can create (the app logs lockouts). Only admins can read/update.
    match /lockout_events/{eventId} {
      allow create: if request.auth != null;
      allow read, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- Messages ---
    // Users can create, read their own messages (sent or received). Admins can read/update all.
    match /messages/{messageId} {
      allow create: if request.auth != null
        && request.resource.data.from_uid == request.auth.uid;
      allow read: if request.auth != null
        && (resource.data.from_uid == request.auth.uid
            || resource.data.to_uid == request.auth.uid
            || resource.data.user_id == request.auth.uid
            || isAdmin());
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.to_uid
            || request.auth.uid == resource.data.from_uid
            || request.auth.uid == resource.data.user_id
            || isAdmin());
      allow delete: if false;
    }

    // --- Vehicle cache ---
    // Read: any authenticated user (needed for cache hits from the app).
    // Write: restricted to admins / Cloud Run service account only.
    // The app writes via VehicleCacheService which runs with the user's auth,
    // so we allow create/update from authenticated users but NOT delete.
    // NOTE: The vrm_normalized field has been removed from cached documents
    // to prevent plaintext VRM exposure. Documents are keyed by SHA-256 hash.
    match /vehicles/{vehicleHash} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && !('vrm_normalized' in request.resource.data);
      allow delete: if isAdmin();
    }

    // --- VDGL Usage Logs ---
    // Only admins can read. Written by Cloud Functions (admin SDK bypasses rules).
    match /vdgl_usage/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Written by Cloud Function via admin SDK
    }

    // --- VDGL Daily Counters ---
    // Only admins can read. Written by Cloud Functions (admin SDK bypasses rules).
    match /vdgl_counters/{dayId} {
      allow read: if isAdmin();
      allow write: if false; // Written by Cloud Function via admin SDK
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

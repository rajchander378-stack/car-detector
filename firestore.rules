rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper: check if the caller is an admin ---
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/config/admin)
        && request.auth.token.email in get(/databases/$(database)/documents/config/admin).data.admin_emails;
    }

    // --- Users ---
    // Users can read/write their own document. Admins can read/update any user.
    // Users cannot change their own plan fields — only admins can.
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan', 'plan_started_at', 'plan_expires_at']);
      allow update: if isAdmin();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Saved scans subcollection — owner only
      match /saved_scans/{scanId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Garage subcollection — owner only
      match /garage/{vehicleId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Usage tracking subcollection — owner can read/write, admins can read
      match /usage/{monthId} {
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow create, update: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- Plan configuration ---
    // Any authenticated user can read plan details. Only admins can modify.
    match /config/plans {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // --- Admin config ---
    // Only admins can read. Only admins can write (except first-time bootstrap).
    match /config/admin {
      // Allow read for any authenticated user (needed to check if they are admin).
      // The admin check itself is done client-side; the sensitive data is just an email list.
      allow read: if request.auth != null;

      // Allow create if no admin doc exists yet (bootstrap by first user)
      allow create: if request.auth != null;

      // Only existing admins can update the admin list
      allow update: if isAdmin();
      allow delete: if false;
    }

    // --- Shared Vehicle Reports ---
    // Anyone can read (public links). Only authenticated owner can create/update/delete.
    match /shared_reports/{reportId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.owner_uid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.owner_uid == request.auth.uid;
    }

    // --- AI Reports ---
    // Authenticated users can create reports. Only admins can read/update/delete.
    match /ai_reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // --- Lockout Events ---
    // Authenticated users can create (the app logs lockouts). Only admins can read/update.
    match /lockout_events/{eventId} {
      allow create: if request.auth != null;
      allow read, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- Messages ---
    // Users can read/create messages they own. Admins can read all and reply.
    match /messages/{messageId} {
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid;
      allow read: if request.auth != null
        && (resource.data.user_id == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
